# ── Supabase (auth + database) ─────────────────────────────────────────────
# Create a free project at https://supabase.com
# Copy from: Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key (Project Settings → API → service_role). SERVER-ONLY — never
# expose this in the client bundle. Required for account self-deletion
# (/api/delete-account), which removes the auth user and cascades their data.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI backend ──────────────────────────────────────────────────────────────
# Gemini API key from https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# ── Analytics (optional) ────────────────────────────────────────────────────
# PostHog project API key from https://posthog.com (free tier available)
REACT_APP_POSTHOG_KEY=phc_xxxxxxxxxxxx
# REACT_APP_POSTHOG_HOST=https://us.i.posthog.com   # default, change for EU

# ── Error monitoring (optional) ─────────────────────────────────────────────
# Sentry DSN from https://sentry.io (free tier available)
REACT_APP_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Email (optional) ────────────────────────────────────────────────────────
# Resend API key from https://resend.com (3k emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Koala Statements <hello@koalastatements.com>

# ── Contact / Feedback form via EmailJS ─────────────────────────────────────
# Create a free account at https://www.emailjs.com — add an Email Service and an
# Email Template, then copy the IDs + Public Key from the dashboard.
# NOTE: REACT_APP_* vars are embedded in the client bundle. The EmailJS Public
# Key is designed to be public, but lock the template down in the EmailJS
# dashboard (allowlist your domain) to prevent abuse.
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxx
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxx
REACT_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ── Rate limiting (optional, recommended for production) ─────────────────────
# Upstash Redis from https://upstash.com (10k commands/day free)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# ── Koala Pro billing via Stripe (unlocks the AI features) ──────────────────
# The AI paywall stays OFF until BOTH the client flag below AND STRIPE_SECRET_KEY
# are set — so the app runs exactly as before until you complete this section.
#
# Setup (https://dashboard.stripe.com):
#   1. Create a Product "Koala Pro" with two recurring Prices:
#        • $9 / month   → copy its price id into STRIPE_PRICE_MONTHLY
#        • $90 / year   → copy its price id into STRIPE_PRICE_YEARLY
#   2. Developers → API keys → copy the Secret key into STRIPE_SECRET_KEY.
#   3. Developers → Webhooks → add endpoint  https://YOUR_DOMAIN/api/stripe-webhook
#        subscribe to: checkout.session.completed,
#                      customer.subscription.updated,
#                      customer.subscription.deleted
#        then copy the "Signing secret" into STRIPE_WEBHOOK_SECRET.
#   4. Run supabase-setup.sql (it now includes the `subscriptions` table).
#   5. Requires SUPABASE_SERVICE_ROLE_KEY (above) so the webhook can write plans.
#
# Client flag — turns the paywall UI on. "1" to enable, unset/anything else = off.
REACT_APP_STRIPE_ENABLED=0
# Server-only Stripe secrets (never REACT_APP_*, never in the client bundle):
STRIPE_SECRET_KEY=sk_live_or_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxx
